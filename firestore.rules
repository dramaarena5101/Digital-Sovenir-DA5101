rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper: Check if user is the document owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    
    // Helper: Check if user is activated
    function isActivated() {
      return isAuth() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activated == true;
    }
    
    // Helper: Check if user is admin
    function isAdmin() {
      return isAuth() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
      
      allow update: if isAdmin() || (isOwner(userId) && (
        (
          // Normal profile update: explicitly block changing role and activated status
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'activated'])
        ) || (
          // Activation update: strictly require linking to a valid used code
          request.resource.data.activated == true &&
          resource.data.activated == false &&
          request.resource.data.role == resource.data.role &&
          get(/databases/$(database)/documents/activation_codes/$(request.resource.data.activationCode)).data.usedBy == request.auth.uid
        )
      ));
    }
    
    // Activation codes
    match /activation_codes/{codeId} {
      // Users can only fetch a specific code to check it, preventing reading the whole collection
      allow get: if isAuth(); 
      allow list: if isAdmin();
      
      allow update: if isAuth() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedBy', 'usedDate']) &&
        resource.data.status == 'unused' &&
        request.resource.data.status == 'used' &&
        request.resource.data.usedBy == request.auth.uid;
        
      allow create, delete: if isAdmin();
    }
    
    // Content collections - read requires activation, write requires admin
    match /videos/{docId} { allow read: if isActivated(); allow write: if isAdmin(); }
    match /photos/{docId} { allow read: if isActivated(); allow write: if isAdmin(); }
    match /audios/{docId} { allow read: if isActivated(); allow write: if isAdmin(); }
    match /documents/{docId} { allow read: if isActivated(); allow write: if isAdmin(); }
    match /rewards/{docId} { allow read: if isActivated(); allow write: if isAdmin(); }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read: if isActivated();
      allow create: if isActivated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || isOwner(resource.data.userId);
      
      allow update: if isActivated() && (
        (
          // Any activated user can toggle likes
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        ) || (
          // Only the owner can edit their own comment text
          isOwner(resource.data.userId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'videoId', 'parentId', 'createdAt'])
        )
      );
    }
  }
}
